# ── LockedSecure Environment Variables ──────────────────
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# --- App Version (overrides defaultConfig in app/build.gradle.kts) ---
# APP_VERSION_NAME=1.0.0
# APP_VERSION_CODE=1

# --- Android Signing (used by CI/CD or local release builds) ---
# ANDROID_SIGNING_KEY_FILE=signing-key.jks
# ANDROID_SIGNING_STORE_PASSWORD=
# ANDROID_SIGNING_KEY_ALIAS=
# ANDROID_SIGNING_KEY_PASSWORD=
